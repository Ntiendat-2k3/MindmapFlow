# ================================
# MindmapFlow — Environment Variables
# ================================
# Copy file này thành .env và điền giá trị thật

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3001

# --- NextAuth ---
NEXTAUTH_SECRET=          # Tạo bằng: openssl rand -hex 32

# --- GitHub OAuth ---
GITHUB_ID=
GITHUB_SECRET=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- API endpoint (relative path for Next.js API Routes) ---
NEXT_PUBLIC_API=/api/mindmap

# --- Database (Neon / Vercel Postgres) ---
DATABASE_URL=
POSTGRES_URL=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
